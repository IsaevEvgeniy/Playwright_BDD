{
  "name": "playwright_bdd",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "bddgen": "npx bddgen",
    "test:chromium": "npx bddgen && npx playwright test --project=chromium",
    "test:firefox": "npx bddgen && npx playwright test --project=firefox",
    "test:webkit": "npx bddgen && npx playwright test --project=webkit",
    "test:all": "npx bddgen && npx playwright test",
    "ci": "npx bddgen && npx playwright test --workers=1 --grep-invert @Performance",
    "debug": "npx bddgen && npx playwright test --project=chromium --debug",
    "ui": "npx bddgen && npx playwright test --project=chromium --ui",
    "test:ui": "npx bddgen && npx playwright test --project=chromium .features-gen/src/features/ui",
    "test:e2e": "npx bddgen && npx playwright test --project=chromium .features-gen/src/features/e2e",
    "test:api": "npx bddgen && npx playwright test --project=chromium .features-gen/src/features/api",
    "sanity": "npx bddgen && npx playwright test --grep @Sanity --project=chromium",
    "smoke": "npx bddgen && npx playwright test --grep @Smoke --project=chromium",
    "regression": "npx bddgen && npx playwright test --grep @Regression --project=chromium",
    "install:browsers": "npx playwright install",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report:open": "npx playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.9.0",
    "playwright-bdd": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
